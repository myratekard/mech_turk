# Gemini (LangChain) — reuse the shared myratekard GOOGLE_API_KEY
GOOGLE_API_KEY=

# Model + generation
GEMINI_MODEL=gemini-2.5-flash
# 0 disables Gemini "thinking" tokens (~5x cheaper, no accuracy loss on our set)
GEMINI_THINKING_BUDGET=0

# Abuse / cost controls
DAILY_UPLOAD_LIMIT=200
PHASH_DISTANCE=5

# Points (negative = penalty)
POINTS_ACCEPTED=50
POINTS_DUPLICATE=-5
POINTS_SELF_DUPLICATE=-10

# Fusion thresholds (see app/services/fusion.py)
BADGE_CV_THRESHOLD=0.76
LLM_CONF_HIGH=0.75
LLM_CONF_MIN=0.40

# Non-phone-screenshot pre-LLM gate (height/width bounds + min short side)
SCREENSHOT_MIN_ASPECT=1.3
SCREENSHOT_MAX_ASPECT=3.0
SCREENSHOT_MIN_SHORT_SIDE=300

# Where analyzed artifacts (JSON + badge crops) + local SQLite/uploads live (dev only)
ARTIFACT_DIR=artifacts

# --- Persistence: SQLite (local default) vs MongoDB (deployed) ---
# Leave MONGO_URI empty for local SQLite. Set it (or DB_BACKEND=mongo) to use MongoDB Atlas.
DB_BACKEND=
MONGO_URI=
MONGO_DB=mech_turk

# --- Object storage: local disk (dev) vs Cloudflare R2 (deployed) ---
# Set all four to switch uploads to R2 (matches the myratekard backend/ai stack).
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_KEY=
CLOUDFLARE_ENDPOINT=
CLOUDFLARE_BUCKET=
CLOUDFLARE_CDN_URL=

# --- Clerk auth ---
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
SUPERUSER_EMAIL=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Auth ---
AUTH_SECRET=change-me-to-a-long-random-string
SUPERUSER_USERNAME=adeyehat
SUPERUSER_PASSWORD=adeyehat123
# Public frontend URL used to build registration links emailed to org admins
APP_BASE_URL=http://localhost:5173

# --- Email (to actually send org-invite links; ZeptoMail preferred, SMTP fallback) ---
# ZeptoMail (matches the myratekard stack):
ZEPTOMAIL_BASE_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_SENDER=
# OR SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
