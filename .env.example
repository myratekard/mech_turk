# Gemini (LangChain) — reuse the shared myratekard GOOGLE_API_KEY
GOOGLE_API_KEY=

# Model + generation
GEMINI_MODEL=gemini-2.5-flash

# Fusion thresholds (see app/services/fusion.py)
CV_MATCH_THRESHOLD=0.72
LLM_CONF_HIGH=0.75
LLM_CONF_MIN=0.40

# Where analyzed artifacts (JSON + badge crops) are written
ARTIFACT_DIR=artifacts

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Auth ---
AUTH_SECRET=change-me-to-a-long-random-string
SUPERUSER_USERNAME=adeyehat
SUPERUSER_PASSWORD=adeyehat123
# Public frontend URL used to build registration links emailed to org admins
APP_BASE_URL=http://localhost:5173

# --- Email (to actually send org-invite links; ZeptoMail preferred, SMTP fallback) ---
# ZeptoMail (matches the myratekard stack):
ZEPTOMAIL_BASE_URL=https://api.zeptomail.com/v1.1/email
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_SENDER=
# OR SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
